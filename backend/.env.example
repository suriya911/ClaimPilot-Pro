# Backend runtime configuration (example only)
# Copy to backend/.env for local testing if needed.

GEMINI_API_KEY=replace_me
GEMINI_MODEL=gemini-2.0-flash-exp
SUGGEST_MODE=llm
LLM_DEBUG=0

# CORS
CORS_ORIGINS=https://your-frontend-domain.com

# AWS S3 upload settings
AWS_REGION=us-east-1
S3_UPLOAD_BUCKET=replace_me_bucket_name
S3_UPLOAD_PREFIX=uploads
S3_PRESIGN_EXPIRES_SECONDS=900
# Optional KMS key for SSE-KMS
# S3_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789012:key/xxxx-xxxx
