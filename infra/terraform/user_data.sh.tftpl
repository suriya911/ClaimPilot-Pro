#!/bin/bash
set -euxo pipefail

dnf update -y
dnf install -y docker awscli nginx
systemctl enable docker
systemctl start docker
systemctl enable nginx

cat >/opt/claimpilot.env <<EOF
GEMINI_API_KEY=${gemini_api_key}
S3_UPLOAD_BUCKET=${s3_bucket}
AWS_REGION=${aws_region}
SUGGEST_MODE=llm
EOF

cat >/etc/nginx/conf.d/claimpilot.conf <<'EOF'
server {
    listen 80 default_server;
    server_name _;
    client_max_body_size 25m;

    location /api/ {
        proxy_pass http://127.0.0.1:8000/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
        proxy_read_timeout 300;
    }

    location = /health {
        return 200 'ok';
        add_header Content-Type text/plain;
    }

    location / {
        return 404;
    }
}
EOF

rm -f /etc/nginx/conf.d/default.conf || true
nginx -t
systemctl restart nginx

ECR_REGISTRY=$(echo "${app_image}" | cut -d/ -f1)
aws ecr get-login-password --region ${aws_region} | docker login --username AWS --password-stdin "$ECR_REGISTRY"
docker pull ${app_image}

docker rm -f claimpilot-backend || true
docker run -d --restart unless-stopped \
  --name claimpilot-backend \
  -p 127.0.0.1:8000:8000 \
  --env-file /opt/claimpilot.env \
  ${app_image}
